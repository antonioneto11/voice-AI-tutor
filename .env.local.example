# Copy to .env.local and fill in.

# --- OpenAI (required) ---
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin

# --- Langfuse tracing (optional) ---
# Leave blank to disable tracing entirely; the app runs unchanged.
# Get keys from Langfuse UI → Settings → API Keys.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# EU: https://cloud.langfuse.com  |  US: https://us.cloud.langfuse.com  |  or your self-hosted URL
LANGFUSE_BASE_URL=https://cloud.langfuse.com
